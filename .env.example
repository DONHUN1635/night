# Supabase projekt beállítások
# Ezeket a Supabase projekt "Settings -> API" menüpontjában találod

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# CSAK szerveroldalon használt, soha ne kerüljön a böngészőbe / git-be
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alkalmazás URL (helyi fejlesztésen és éles környezetben is állítsd be)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Minimum életkor a regisztrációhoz
NEXT_PUBLIC_MIN_AGE=18
CRON_SECRET=mennyelinnenafenebetegyerekmertmegverlek
